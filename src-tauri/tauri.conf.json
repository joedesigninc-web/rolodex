{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rolodex",
  "version": "0.1.2",
  "identifier": "com.joedesign.rolodex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
 "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Rolodex",
        "label": "main",
        "width": 480,
        "height": 640,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
